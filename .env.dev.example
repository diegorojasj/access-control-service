# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234
POSTGRES_DB=access_control_service
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Frontend (Bun dev server — read directly by src/index.ts)
BUN_PUBLIC_NODE_ENV=development
BUN_PUBLIC_FRONTEND_PORT=3000
BUN_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
EXPIRES_IN=10800

## Enable auto-reload in development
RELOAD=true

## Logging
LOG_LEVEL=debug
ACCESS_LOG=true

## Workers (recommended for development)
WORKERS=1

## Lifespan handling
LIFESPAN=auto

## HTTP protocol implementation
HTTP=auto

## WebSocket implementation
WS=auto

## Proxy headers (if behind nginx / load balancer)
PROXY_HEADERS=true
FORWARDED_ALLOW_IPS=*

## Limit max requests before restart (helps memory leaks)
LIMIT_MAX_REQUESTS=
