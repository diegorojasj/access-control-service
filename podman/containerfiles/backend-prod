FROM python:3.12-alpine

# Prevent Python from buffering stdout/stderr
ENV PYTHONUNBUFFERED=1
WORKDIR /app

# Copy backend code and install deps (leverage Docker layer caching)
RUN python -m pip install --no-cache-dir -r /app/requirements.txt

# Copy the backend source
COPY backend/ /app/

# Expose backend port
EXPOSE 8000

# Entrypoint (kept for any runtime setup you have)
COPY docker/dockerfiles/entrypoints/entrypoint-python.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]

# Production command: gunicorn without reload (with proper logging)
CMD ["gunicorn", "main:app", "-k", "uvicorn.workers.UvicornWorker", "-w", "2", "--access-logfile", "-", "--error-logfile", "-", "--log-level", "info"]
